{
  "name": "barber-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm -w apps/web run dev",
    "build": "npm -w apps/web run build",
    "start": "npm -w apps/web run start",
    "lint": "npm -w apps/web run lint",
    "types:generate": "npx --yes tsx scripts/generate-types.ts",
    "types:generate:local": "SUPABASE_GEN_MODE=local npx --yes tsx scripts/generate-types.ts",
    "types:generate:auto": "node scripts/types-generate-auto.js",
    "webhook:check-config": "node scripts/check-webhook-config.js",
    "webhook:manual-booking": "node scripts/manually-create-booking-from-payment.js",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "security:check": "npm audit --audit-level=moderate",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "android": "npm -w apps/mobile run android",
    "ios": "npm -w apps/mobile run ios",
    "test": "npm -w apps/web run test && npm -w packages/shared run test",
    "test:watch": "npm -w apps/web run test:watch",
    "test:coverage": "npm -w apps/web run test:coverage",
    "test:ci": "npm -w apps/web run test:ci",
    "test:shared": "npm -w packages/shared run test",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:api": "jest --testPathPattern=api",
    "test:components": "jest --testPathPattern=components",
    "test:utils": "jest --testPathPattern=utils",
    "test:integration": "jest --testPathPattern=integration"
  },
  "dependencies": {
    "radix-ui": "^1.4.3"
  }
}
